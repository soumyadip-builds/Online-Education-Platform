8;&amp;quot;externallink&amp;quot;,&amp;quot;htmlTitle&amp;quot;&amp;#58;&amp;quot;&amp;lt;h2 class=\&amp;quot;headingSpacingAbove headingSpacingBelow lineHeight1_4\&amp;quot;&amp;gt;&amp;lt;span class=\&amp;quot;fontSizeXLarge\&amp;quot;&amp;gt;GenC Digital Honors&amp;lt;/span&amp;gt;&amp;lt;/h2&amp;gt;&amp;quot;,&amp;quot;showTimeToRead&amp;quot;&amp;#58;false,&amp;quot;encodedImage&amp;quot;&amp;#58;&amp;quot;B813;CQku6n.W-n,&amp;quot;&amp;#125;,&amp;quot;containsDynamicDataSource&amp;quot;&amp;#58;false&amp;#125;&quot;&gt;&lt;div data-sp-componentid=&quot;cbe7b0a9-3504-44dd-a3a3-0e5cacd07788&quot;&gt;&lt;/div&gt;&lt;div data-sp-htmlproperties=&quot;&quot;&gt;&lt;img data-sp-prop-name=&quot;imageSource&quot; src=&quot;/sites/GlobalHR/SiteAssets/SitePages/Template-Page/33602-banner--2-.svg&quot; data-sp-cust-siteId=&quot;be586e5c-f14e-465a-a7f0-5bf5a8049e74&quot; data-sp-cust-webId=&quot;5822877b-80cb-40b2-8e63-22ef750ca0ea&quot; data-sp-cust-listId=&quot;1569357f-d947-4e53-b160-67fe3ec4e250&quot; data-sp-cust-uniqueId=&quot;f59cb844-5ad8-45e1-ad6a-0e7d81578d49&quot; data-sp-cust-width=&quot;1366&quot; data-sp-cust-height=&quot;207&quot; /&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div data-sp-canvascontrol=&quot;&quot; data-sp-canvasdataversion=&quot;1.0&quot; data-sp-controldata=&quot;&amp;#123;&amp;quot;position&amp;quot;&amp;#58;&amp;#123;&amp;quot;layoutIndex&amp;quot;&amp;#58;1,&amp;quot;zoneIndex&amp;quot;&amp;#58;2,&amp;quot;zoneId&amp;quot;&amp;#58;&amp;quot;70b3e5e9-8b29-4d70-9780-ea16a469c34e&amp;quot;,&amp;quot;sectionIndex&amp;quot;&amp;#58;1,&amp;quot;sectionFactor&amp;quot;&amp;#58;12,&amp;quot;controlIndex&amp;quot;&amp;#58;1&amp;#125;,&amp;quot;id&amp;quot;&amp;#58;&amp;quot;3e95a108-514f-4780-bdee-6b80f01ae83a&amp;quot;,&amp;quot;controlType&amp;quot;&amp;#58;4,&amp;quot;isFromSectionTemplate&amp;quot;&amp;#58;false,&amp;quot;addedFromPersistedData&amp;quot;&amp;#58;true,&amp;quot;contentVersion&amp;quot;&amp;#58;5&amp;#125;&quot;&gt;&lt;div data-sp-rte=&quot;&quot;&gt;&lt;h4&gt;&lt;span class=&quot;fontColorThemePrimary&quot;&gt;&lt;strong&gt;ABOUT THE PROGRAM&lt;/strong&gt;&lt;/span&gt;&lt;/h4&gt;&lt;p&gt;Career aspirations are a huge motivator for success. We are pleased to launch&lt;strong&gt;&amp;#160;&lt;/strong&gt;&lt;span class=&quot;fontColorThemePrimary&quot;&gt;&lt;strong&gt;GenC Digital Honors&lt;/strong&gt;,&lt;/span&gt; a program dedicated to accelerated growth and career progression of self-driven, high performing India GenC associates. This program is an opportunity for all&amp;#160;&lt;strong&gt;GenCs&lt;/strong&gt;&amp;#160;at&amp;#160;&lt;span class=&quot;fontColorThemePrimary&quot;&gt;&lt;strong&gt;Programmer Analyst Trainee (PAT)&lt;/strong&gt;&lt;/span&gt;&amp;#160;and&amp;#160;&lt;span class=&quot;fontColorThemePrimary&quot;&gt;&lt;strong&gt;Program Analyst (PA)&lt;/strong&gt;&lt;/span&gt;&amp;#160;grade in India to get one step closer to the&amp;#160;&lt;strong&gt;GenC Next / GenC Pro&lt;/strong&gt;&amp;#160;role, while fulfilling your career aspirations.&lt;/p&gt;&lt;p&gt;GenC Digital Honors provides eligible associates (GenCs), an opportunity to apply for a GenC Next / GenC Pro role, also allows them to&amp;#160;&lt;strong&gt;upskill&lt;/strong&gt;&amp;#160;during the program and help ready them to take on a new role with different, more challenging demands.&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div data-sp-canvascontrol=&quot;&quot; data-sp-canvasdataversion=&quot;1.0&quot; data-sp-controldata=&quot;&amp;#123;&amp;quot;position&amp;quot;&amp;#58;&amp;#123;&amp;quot;layoutIndex&amp;quot;&amp;#58;1,&amp;quot;zoneIndex&amp;quot;&amp;#58;3,&amp;quot;zoneId&amp;quot;&amp;#58;&amp;quot;51bb1461-239d-4871-a8a6-610ee1a3b548&amp;quot;,&amp;quot;sectionIndex&amp;quot;&amp;#58;1,&amp;quot;sectionFactor&amp;quot;&amp;#58;6,&amp;quot;controlIndex&amp;quot;&amp;#58;1&amp;#125;,&amp;quot;emphasis&amp;quot;&amp;#58;&amp;#123;&amp;quot;zoneEmphasis&amp;quot;&amp;#58;2&amp;#125;,&amp;quot;id&amp;quot;&amp;#58;&amp;quot;6e3e2f58-30c6-4934-bb85-f83ead1a298e&amp;quot;,&amp;quot;controlType&amp;quot;&amp;#58;4,&amp;quot;isFromSectionTemplate&amp;quot;&amp;#58;false,&amp;quot;addedFromPersistedData&amp;quot;&amp;#58;true,&amp;quot;contentVersion&amp;quot;&amp;#58;5&amp;#125;&quot;&gt;&lt;div data-sp-rte=&quot;&quot;&gt;&lt;p&gt;&lt;span class=&quot;fontColorThemeDarkAlt&quot;&gt;&lt;strong&gt;GenC Next&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span class=&quot;fontColorThemeDarkAlt&quot;&gt;&lt;strong&gt;​​​​​​​&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Potential GenC Next associates need to be technically proficient with advanced programming skills and full stack abilities.&lt;/p&gt;&lt;p&gt;The associate may also have&amp;#160;&lt;strong&gt;advanced proficiency levels&lt;/strong&gt;&amp;#160;in enterprise platforms/products/specific technologies such as Salesforce, PEGA and more. They should be able to solve technology challenges and provide articulate explanations for every solution.&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div data-sp-canvascontrol=&quot;&quot; data-sp-canvasdataversion=&quot;1.0&quot; data-sp-controldata=&quot;&amp;#123;&amp;quot;position&amp;quot;&amp;#58;&amp;#123;&amp;quot;layoutIndex&amp;quot;&amp;#58;1,&amp;quot;zoneIndex&amp;quot;&amp;#58;3,&amp;quot;zoneId&amp;quot;&amp;#58;&amp;quot;51bb1461-239d-4871-a8a6-610ee1a3b548&amp;quot;,&amp;quot;sectionIndex&amp;quot;&amp;#58;2,&amp;quot;sectionFactor&amp;quot;&amp;#58;6,&amp;quot;controlIndex&amp;quot;&amp;#58;1&amp;#125;,&amp;quot;emphasis&amp;quot;&amp;#58;&amp;#123;&amp;quot;zoneEmphasis&amp;quot;&amp;#58;2&amp;#125;,&amp;quot;id&amp;quot;&amp;#58;&amp;quot;594649a4-e22c-4fd2-9cf6-8bddae058929&amp;quot;,&amp;quot;controlType&amp;quot;&amp;#58;4,&amp;quot;isFromSectionTemplate&amp;quot;&amp;#58;false,&amp;quot;addedFromPersistedData&amp;quot;&amp;#58;true,&amp;quot;contentVersion&amp;quot;&amp;#58;5&amp;#125;&quot;&gt;&lt;div data-sp-rte=&quot;&quot;&gt;&lt;p&gt;&lt;span class=&quot;fontColorThemeDarkAlt&quot;&gt;&lt;strong&gt;GenC Pro&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span class=&quot;fontColorThemeDarkAlt&quot;&gt;&lt;strong&gt;​​​​​​​&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Potential GenC Pro associates need to possess expertise in enterprise platforms/products/specific technologies, such as Salesforce, PEGA, SAP, Cybersecurity, ServiceNow and more. Their skill proficiency allows them to accelerate their deployment to business projects.&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div data-sp-canvascontrol=&quot;&quot; data-sp-canvasdataversion=&quot;1.0&quot; data-sp-controldata=&quot;&amp;#123;&amp;quot;position&amp;quot;&amp;#58;&amp;#123;&amp;quot;layoutIndex&amp;quot;&amp;#58;1,&amp;quot;zoneIndex&amp;quot;&amp;#58;4,&amp;quot;zoneId&amp;quot;&amp;#58;&amp;quot;dd83e897-7bdf-4362-8075-ad4963553a9a&amp;quot;,&amp;quot;sectionIndex&amp;quot;&amp;#58;1,&amp;quot;sectionFactor&amp;quot;&amp;#58;12,&amp;quot;controlIndex&amp;quot;&amp;#58;1&amp;#125;,&amp;quot;id&amp;quot;&amp;#58;&amp;quot;42f39a5b-64ef-46d5-ab66-c2b32129e57d&amp;quot;,&amp;quot;controlType&amp;quot;&amp;#58;4,&amp;quot;isFromSectionTemplate&amp;quot;&amp;#58;false,&amp;quot;addedFromPersistedData&amp;quot;&amp;#58;true,&amp;quot;contentVersion&amp;quot;&amp;#58;5&amp;#125;&quot;&gt;&lt;div data-sp-rte=&quot;&quot;&gt;&lt;h4&gt;&lt;span class=&quot;fontColorThemePrimary&quot;&gt;&lt;strong&gt;ELIGIBILITY CRITERIA&lt;/strong&gt;&lt;/span&gt;&lt;/h4&gt;&lt;ol class=&quot;customListStyle&quot;&gt;&lt;li data-list-item-id=&quot;e38031957395b252a3bc422cdc48c3a7f&quot;&gt;All ‘Programmer Analyst Trainees (PAT)’ who have completed minimum of 6 months in Cognizant as of the cut-off date specified in the list of available roles (refer table below)&lt;/li&gt;&lt;li data-list-item-id=&quot;eb99d05b9dd61c1d767c1c59aebc0f105&quot;&gt;All ‘Programmer Analyst (PA)’ excluding Lateral Hires&lt;/li&gt;&lt;li data-list-item-id=&quot;e99f19a4f37acb79965a4170a87780bab&quot;&gt;P